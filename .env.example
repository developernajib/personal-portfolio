# GitHub Personal Access Token (classic)
# Required for the GitHub Activity contribution graph (uses GitHub GraphQL API).
# Scopes needed: read:user
# Generate at: https://github.com/settings/tokens
VITE_GITHUB_TOKEN=your_github_token_here

# Google Drive resume link (File > Share > Copy link, then change /view to /preview or keep as-is)
# Must be a publicly accessible link. Opens in a new tab when clicked.
VITE_RESUME_URL=https://drive.google.com/file/d/YOUR_FILE_ID/view?usp=sharing
